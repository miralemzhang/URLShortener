# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — .env.local is secret, .env is safe to commit (only contains local file path)
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma generated client (reviewer runs `npx prisma generate`)
/src/generated/prisma

# SQLite database (reviewer runs `npx prisma migrate deploy`)
*.db
*.db-shm
*.db-wal
